# ─── kalos.vzla — variables de entorno ───────────────────────────────────────
# Copia este archivo como `.env` y completa los valores reales.

# Número de WhatsApp del negocio (solo dígitos, sin +, sin espacios).
# +58 424 626-3545  →  584246263545
VITE_WHATSAPP_NUMBER=584246263545

# Fuente de datos: "local" (localStorage) o "supabase"
VITE_DATA_SOURCE=local

# Contraseña del panel de administración (temporal — reemplazar con Supabase Auth)
VITE_ADMIN_PASSCODE=kalos2024

# ─── Supabase (solo necesario si VITE_DATA_SOURCE=supabase) ──────────────────
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
